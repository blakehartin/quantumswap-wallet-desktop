{
  "name": "quantumswapwallet",
  "productName": "QuantumSwapWallet",
  "version": "1.2.6",
  "description": "QuantumSwapWallet",
  "main": "dist/electron/main.js",
  "author": "QuantumSwap Community",
  "license": "MIT",
  "scripts": {
    "start": "npm run build && electron .",
    "build": "tsc -p tsconfig.json --noEmit && vite build && tsc -p tsconfig.electron.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "dist": "npm run build && electron-builder",
    "publish": "npm run build && electron-builder --publish always",
    "build-icons": "node scripts/build-icons.js",
    "build-mac": "npm run build && electron-builder --mac",
    "build-win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.0",
    "quantumcoin": "^8.0.3",
    "quantumswap": "^1.0.3",
    "seed-words": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.16.0"
  },
  "overrides": {
    "rimraf": "^5.0.5",
    "glob": "^13.0.6",
    "tar": "^7.0.0",
    "boolean": "^3.2.1"
  },
  "allowScripts": {
    "electron": true,
    "electron-winstaller": true
  },
  "build": {
    "appId": "com.quantumswap.wallet",
    "productName": "QuantumSwapWallet",
    "asar": true,
    "files": [
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "public/assets/icons/app/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "icon": "build/icon-trans.icns"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.dmg",
      "icon": "build/icon-trans.icns",
      "sign": false
    },
    "publish": [
      {
        "provider": "github",
        "repo": "quantumswap-wallet-desktop",
        "releaseType": "release"
      }
    ]
  }
}
